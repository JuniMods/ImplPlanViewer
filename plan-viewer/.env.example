# GitHub API configuration for the web app
VITE_GITHUB_TOKEN=
VITE_GITHUB_ORG=
VITE_GITHUB_TOPIC=impl-plan-viewer

# Repository discovery mode: topic | org
VITE_DISCOVERY_MODE=topic

# Optional comma-separated repository filters
VITE_INCLUDE_REPOS=
VITE_EXCLUDE_REPOS=

# Optional analytics (Google Analytics gtag)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_MEASUREMENT_ID=
